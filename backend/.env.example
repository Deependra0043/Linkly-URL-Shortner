# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# Replace with your local MongoDB URI or MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017/linkly_db

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------
# Generate a strong 64-character secret string for production (e.g., openssl rand -base64 32)
JWT_SECRET=your_jwt_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Rate Limiting Settings
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX=100         # Max requests per window per IP